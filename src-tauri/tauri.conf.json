{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Text Actions",
  "version": "0.1.0",
  "identifier": "com.yourname.ai-text-actions",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "panel",
        "title": "AI Text Actions",
        "url": "/panel",
        "width": 380,
        "height": 240,
        "minWidth": 380,
        "minHeight": 200,
        "maxWidth": 380,
        "maxHeight": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": true,
        "focus": false,
        "acceptFirstMouse": true,
        "hiddenTitle": true,
        "titleBarStyle": "Transparent"
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "/settings",
        "width": 720,
        "height": 540,
        "visible": false,
        "resizable": true,
        "minWidth": 600,
        "minHeight": 400
      },
      {
        "label": "onboarding",
        "title": "Welcome",
        "url": "/onboarding",
        "width": 640,
        "height": 480,
        "visible": false,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "AI text actions, OS-wide",
    "longDescription": "Select text in any app, press a hotkey, apply an AI action. Results stream into a floating panel and replace your selection."
  },
  "plugins": {}
}
